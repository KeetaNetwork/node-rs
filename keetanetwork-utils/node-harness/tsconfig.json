{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["DOM", "ES2020", "ES2021.WeakRef", "ESNext.Disposable"],
		"rootDir": "./src",
		"module": "commonjs",
		"moduleResolution": "node",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": false,
		"outDir": "dist",
		"sourceMap": true,
		"types": ["node"]
	},
	"include": [
		"src/**/*.ts"
	]
}
